# PostgreSQL
# - Local dev: you can set DATABASE_URL and DIRECT_URL to the same local connection string.
# - Hosted (Supabase): set DATABASE_URL to the pooler/transaction URL (if using it) and DIRECT_URL to the direct DB URL.
DATABASE_URL="postgresql://user:password@localhost:5432/feedpilot?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/feedpilot?schema=public"

# Redis — provided by Railway when you add the Redis plugin
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Public app URL (used for callbacks, exports, etc.)
APP_URL="http://localhost:3000"

# Node env
NODE_ENV="development"
